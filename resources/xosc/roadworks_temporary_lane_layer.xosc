<?xml version="1.0" encoding="UTF-8"?>
<OpenSCENARIO>
    <FileHeader revMajor="1" revMinor="4" date="2026-05-29T18:00:00" description="Construction site with temporary lane layers test scenario" author="johschmitz"/>
    <CatalogLocations/>
    <RoadNetwork>
        <LogicFile filepath="../xodr/roadworks_permanent_temporary_layers.xodr"/>
    </RoadNetwork>
    <Entities>
        <ScenarioObject name="Ego">
            <Vehicle name="car_white" vehicleCategory="car">
