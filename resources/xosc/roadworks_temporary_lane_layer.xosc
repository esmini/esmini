                    <Dimensions width="2.0" height="1.8" length="4.5"/>
                </BoundingBox>
                <Axles>
                    <FrontAxle maxSteering="0.523598776" wheelDiameter="0.6" trackWidth="1.8" positionX="2.8" positionZ="0.3"/>
                    <RearAxle maxSteering="0.0" wheelDiameter="0.6" trackWidth="1.8" positionX="0.0" positionZ="0.3"/>
                </Axles>
                <Properties>
