                <ParameterDeclarations/>
                <Performance maxSpeed="69" maxAcceleration="3.0" maxDeceleration="10.0"/>
                <BoundingBox>
                    <Center x="1.4" y="0.0" z="0.9"/>
                    <Dimensions width="2.0" height="1.8" length="4.5"/>
