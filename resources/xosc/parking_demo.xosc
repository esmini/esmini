                            </Position>
                        </TeleportAction>
                    </PrivateAction>
                    <PrivateAction>
                        <ActivateControllerAction longitudinal="true" lateral="true" />
                    </PrivateAction>
                    <PrivateAction>
                        <LongitudinalAction>
