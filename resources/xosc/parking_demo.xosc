<?xml version="1.0" encoding="UTF-8"?>
<OpenSCENARIO>
    <FileHeader revMajor="1" revMinor="3" date="2026-06-02T10:00:00" description="demo scenario for road object parking and markings modeling"
        author="esmini team" />
    <ParameterDeclarations>
        <ParameterDeclaration name="WhiteCar" parameterType="string" value="car_white" />
        <ParameterDeclaration name="RedCar" parameterType="string" value="car_red" />
        <ParameterDeclaration name="BlueCar" parameterType="string" value="car_blue" />
        <ParameterDeclaration name="Man" parameterType="string" value="pedestrian_adult" />
        <ParameterDeclaration name="Speed" parameterType="double" value="30" />
        <ParameterDeclaration name="CameraStartTime" parameterType="double" value="5" />
    </ParameterDeclarations>
    <CatalogLocations>
        <VehicleCatalog>
            <Directory path="../xosc/Catalogs/Vehicles" />
        </VehicleCatalog>
        <PedestrianCatalog>
            <Directory path="../xosc/Catalogs/Pedestrians" />
        </PedestrianCatalog>
        <ManeuverCatalog>
            <Directory path="../xosc/Catalogs/Maneuvers" />
        </ManeuverCatalog>
    </CatalogLocations>
    <RoadNetwork>
        <LogicFile filepath="../xodr/parking_demo.xodr" />
    </RoadNetwork>
    <Entities>
        <ScenarioObject name="Target0">
            <CatalogReference catalogName="VehicleCatalog" entryName="$WhiteCar" />
        </ScenarioObject>
        <ScenarioObject name="Target">
            <CatalogReference catalogName="VehicleCatalog" entryName="$BlueCar" />
        </ScenarioObject>
        <ScenarioObject name="Target1">
