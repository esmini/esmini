                                <WorldPosition x="104.0" y="4.2" z="0" h="1.5" p="0" r="0" />
                            </Position>
                        </TeleportAction>
                    </PrivateAction>
                    <PrivateAction>
                        <ActivateControllerAction longitudinal="true" lateral="true" />
