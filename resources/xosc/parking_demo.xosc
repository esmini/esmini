            </Actions>
        </Init>
        <Story name="MyStory">
            <Act name="Act">
                <ManeuverGroup name="Target3ManeuverGroup" maximumExecutionCount="1">
                    <Actors selectTriggeringEntities="false">
                        <EntityRef entityRef="Target3" />
                    </Actors>
                    <CatalogReference catalogName="LightStateManeuvers" entryName="LightsOnWhenDrivingManeuver">
                        <ParameterAssignments>
                            <ParameterAssignment parameterRef="EntityName" value="Target3" />
                        </ParameterAssignments>
                    </CatalogReference>
                    <Maneuver name="Target3SpeedManeuver">
                        <Event name="Target3SpeedEvent" priority="parallel">
                            <Action name="Target3Action">
                                <PrivateAction>
                                    <LongitudinalAction>
                                        <SpeedAction>
                                            <SpeedActionDynamics dynamicsShape="linear" dynamicsDimension="time" value="7" />
                                            <SpeedActionTarget>
                                                <AbsoluteTargetSpeed value="0" />
                                            </SpeedActionTarget>
                                        </SpeedAction>
                                    </LongitudinalAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target3TrajStartTrigger" delay="0" conditionEdge="none">
                                        <ByEntityCondition>
                                            <TriggeringEntities triggeringEntitiesRule="any">
                                                <EntityRef entityRef="Target3" />
                                            </TriggeringEntities>
                                            <EntityCondition>
                                                <TraveledDistanceCondition value="39.2" />
                                            </EntityCondition>
                                        </ByEntityCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="Target3IndicatorEvent" priority="parallel">
                            <Action name="Target3IndicatorAction">
                                <PrivateAction>
                                    <AppearanceAction>
                                        <LightStateAction>
                                            <LightType>
                                                <VehicleLight vehicleLightType="indicatorRight" />
                                            </LightType>
                                            <LightState mode="flashing" luminousIntensity="600" />
                                        </LightStateAction>
                                    </AppearanceAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target3IndicatorStartTrigger" delay="0.0" conditionEdge="none">
                                        <ByValueCondition>
                                            <StoryboardElementStateCondition storyboardElementRef="Target3SpeedEvent" state="startTransition"
                                                storyboardElementType="event" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="Target3TrajEvent" priority="parallel">
                            <Action name="Target3TrajAction">
                                <PrivateAction>
                                    <RoutingAction>
                                        <FollowTrajectoryAction>
                                            <TimeReference>
                                                <None />
                                            </TimeReference>
                                            <TrajectoryFollowingMode followingMode="position" />
                                            <TrajectoryRef>
                                                <Trajectory name="trajectory_car" closed="false">
                                                    <Shape>
                                                        <Clothoid curvature="0.0" curvatureDot="-0.011" length="12">
                                                            <Position>
                                                                <RelativeWorldPosition dx="0" dy="0" entityRef="Target3" />
                                                            </Position>
                                                        </Clothoid>
                                                    </Shape>
                                                </Trajectory>
                                            </TrajectoryRef>
                                        </FollowTrajectoryAction>
                                    </RoutingAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target3TrajStartTrigger" delay="2.5" conditionEdge="none">
                                        <ByValueCondition>
                                            <StoryboardElementStateCondition storyboardElementRef="Target3SpeedEvent" state="startTransition"
                                                storyboardElementType="event" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                    </Maneuver>
                </ManeuverGroup>
                <ManeuverGroup name="Target4Traj1ManeuverGroup" maximumExecutionCount="1">
                    <Actors selectTriggeringEntities="false">
                        <EntityRef entityRef="Target4" />
                    </Actors>
                    <CatalogReference catalogName="LightStateManeuvers" entryName="LightsOnWhenDrivingManeuver">
                        <ParameterAssignments>
                            <ParameterAssignment parameterRef="EntityName" value="Target4" />
                        </ParameterAssignments>
                    </CatalogReference>
                    <Maneuver name="Target4Traj1Maneuver">
                        <Event name="Target3IndicatorEvent" priority="parallel">
                            <Action name="Target3IndicatorAction">
                                <PrivateAction>
                                    <AppearanceAction>
                                        <LightStateAction>
                                            <LightType>
                                                <VehicleLight vehicleLightType="indicatorLeft" />
                                            </LightType>
                                            <LightState mode="flashing" luminousIntensity="600" />
                                        </LightStateAction>
                                    </AppearanceAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target3IndicatorStartTrigger" delay="0.0" conditionEdge="none">
                                        <ByEntityCondition>
                                            <TriggeringEntities triggeringEntitiesRule="any">
                                                <EntityRef entityRef="Target4" />
                                            </TriggeringEntities>
                                            <EntityCondition>
                                                <TraveledDistanceCondition value="80.0" />
                                            </EntityCondition>
                                        </ByEntityCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="Target4Traj1Event" priority="parallel">
                            <Action name="Target4StopAction">
                                <PrivateAction>
                                    <LongitudinalAction>
                                        <SpeedAction>
                                            <SpeedActionDynamics dynamicsShape="linear" dynamicsDimension="rate" value="1.2" />
                                            <SpeedActionTarget>
                                                <AbsoluteTargetSpeed value="0" />
                                            </SpeedActionTarget>
                                        </SpeedAction>
                                    </LongitudinalAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target4StopStartTrigger" delay="0" conditionEdge="none">
                                        <ByEntityCondition>
                                            <TriggeringEntities triggeringEntitiesRule="any">
                                                <EntityRef entityRef="Target4" />
                                            </TriggeringEntities>
                                            <EntityCondition>
                                                <TraveledDistanceCondition value="92.0" />
                                            </EntityCondition>
                                        </ByEntityCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="Target4TrajEvent" priority="parallel">
                            <Action name="Target4TrajAction">
                                <PrivateAction>
                                    <RoutingAction>
                                        <FollowTrajectoryAction>
                                            <TimeReference>
                                                <None />
                                            </TimeReference>
                                            <TrajectoryFollowingMode followingMode="position" />
                                            <TrajectoryRef>
                                                <Trajectory name="trajectory_car" closed="false">
                                                    <Shape>
                                                        <ClothoidSpline>
                                                            <ClothoidSplineSegment curvatureStart="-0.05" curvatureEnd="0.25" length="12.5"></ClothoidSplineSegment>
                                                            <ClothoidSplineSegment curvatureStart="0.25" curvatureEnd="0.0" length="1.0"></ClothoidSplineSegment>
                                                        </ClothoidSpline>
                                                    </Shape>
                                                </Trajectory>
                                            </TrajectoryRef>
                                        </FollowTrajectoryAction>
                                    </RoutingAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target4StartTrigger" delay="2.25" conditionEdge="none">
                                        <ByValueCondition>
                                            <StoryboardElementStateCondition storyboardElementRef="Target4Traj1Event" state="startTransition"
                                                storyboardElementType="event" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="Target3IndicatorStopEvent" priority="parallel">
                            <Action name="Target3IndicatorStopAction">
                                <PrivateAction>
                                    <AppearanceAction>
                                        <LightStateAction>
                                            <LightType>
                                                <VehicleLight vehicleLightType="indicatorLeft" />
                                            </LightType>
                                            <LightState mode="off" />
                                        </LightStateAction>
                                    </AppearanceAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target3IndicatorStopTrigger" delay="3.5" conditionEdge="none">
                                        <ByValueCondition>
                                            <StoryboardElementStateCondition storyboardElementRef="Target4TrajEvent" state="startTransition"
                                                storyboardElementType="event" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                    </Maneuver>
                </ManeuverGroup>
                <ManeuverGroup name="Target5ManeuverGroup" maximumExecutionCount="1">
                    <Actors selectTriggeringEntities="false">
                        <EntityRef entityRef="Target5" />
                    </Actors>
                    <CatalogReference catalogName="LightStateManeuvers" entryName="LightsOnWhenDrivingManeuver">
                        <ParameterAssignments>
                            <ParameterAssignment parameterRef="EntityName" value="Target5" />
                        </ParameterAssignments>
                    </CatalogReference>
                    <Maneuver name="Target5LightManeuver">
                        <Event name="Target5IndicatorOnEvent" priority="parallel">
                            <Action name="Target5IndicatorOnAction">
                                <PrivateAction>
                                    <AppearanceAction>
                                        <LightStateAction>
                                            <LightType>
                                                <VehicleLight vehicleLightType="indicatorRight" />
                                            </LightType>
                                            <LightState mode="flashing" luminousIntensity="600" />
                                        </LightStateAction>
                                    </AppearanceAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target6ManStopStartTrigger" delay="0" conditionEdge="none">
                                        <ByValueCondition>
                                            <SimulationTimeCondition value="29" rule="greaterOrEqual" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="Target5IndicatorOffEvent" priority="parallel">
                            <Action name="Target5IndicatorOffAction">
                                <PrivateAction>
                                    <AppearanceAction>
                                        <LightStateAction>
                                            <LightType>
                                                <VehicleLight vehicleLightType="indicatorRight" />
                                            </LightType>
                                            <LightState mode="off" />
                                        </LightStateAction>
                                    </AppearanceAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target6ManStopStartTrigger" delay="7" conditionEdge="none">
                                        <ByValueCondition>
                                            <StoryboardElementStateCondition storyboardElementRef="Target5SlowDownEvent" state="startTransition"
                                                storyboardElementType="event" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                    </Maneuver>
                    <Maneuver name="Target5UnparkManuever">
                        <Event name="Target5UnparkEvent" priority="parallel">
                            <Action name="ReverseActionToEstablishDirection">
                                <PrivateAction>
                                    <LongitudinalAction>
                                        <SpeedAction>
                                            <SpeedActionDynamics dynamicsDimension="time" dynamicsShape="step" value="1" />
                                            <SpeedActionTarget>
                                                <AbsoluteTargetSpeed value="-0.01" />
                                            </SpeedActionTarget>
                                        </SpeedAction>
                                    </LongitudinalAction>
                                </PrivateAction>
                            </Action>
                            <Action name="ReverseAction">
                                <PrivateAction>
                                    <LongitudinalAction>
                                        <SpeedAction>
                                            <SpeedActionDynamics dynamicsDimension="rate" dynamicsShape="linear" value="1" />
                                            <SpeedActionTarget>
                                                <AbsoluteTargetSpeed value="-5" />
                                            </SpeedActionTarget>
                                        </SpeedAction>
                                    </LongitudinalAction>
                                </PrivateAction>
                            </Action>
                            <Action name="Target5UnparkTrajAction">
                                <PrivateAction>
                                    <RoutingAction>
                                        <FollowTrajectoryAction>
                                            <TimeReference>
                                                <None />
                                            </TimeReference>
                                            <TrajectoryFollowingMode followingMode="position" />
                                            <TrajectoryRef>
                                                <Trajectory name="trajectory_car" closed="false">
                                                    <Shape>
                                                        <ClothoidSpline>
                                                            <ClothoidSplineSegment curvatureStart="0.0" curvatureEnd="-0.3" length="5.0">
                                                                <PositionStart>
                                                                    <RelativeWorldPosition entityRef="Target5" dx="0" dy="0">
                                                                        <Orientation type="relative" h="${pi}" />
                                                                    </RelativeWorldPosition>
                                                                </PositionStart>
                                                            </ClothoidSplineSegment>
                                                            <ClothoidSplineSegment curvatureStart="-0.3" curvatureEnd="0.0" length="5"></ClothoidSplineSegment>
                                                        </ClothoidSpline>
                                                    </Shape>
                                                </Trajectory>
                                            </TrajectoryRef>
                                        </FollowTrajectoryAction>
                                    </RoutingAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition conditionEdge="none" delay="0.1" name="">
                                        <ByValueCondition>
                                            <SimulationTimeCondition rule="greaterOrEqual" value="15" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="Target5DriveForwardEvent" priority="override">
                            <Action name="ReverseAction">
                                <PrivateAction>
                                    <LongitudinalAction>
                                        <SpeedAction>
                                            <SpeedActionDynamics dynamicsDimension="rate" dynamicsShape="linear" value="4" />
                                            <SpeedActionTarget>
                                                <AbsoluteTargetSpeed value="${30/3.6}" />
                                            </SpeedActionTarget>
                                        </SpeedAction>
                                    </LongitudinalAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition conditionEdge="none" delay="0.1" name="">
                                        <ByValueCondition>
                                            <StoryboardElementStateCondition storyboardElementRef="Target5UnparkEvent" state="completeState"
                                                storyboardElementType="event" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="Target5SlowDownEvent" priority="override">
                            <Action name="Target5SlowDownAction">
                                <PrivateAction>
                                    <LongitudinalAction>
                                        <SpeedAction>
                                            <SpeedActionDynamics dynamicsShape="linear" dynamicsDimension="rate" value="1.0" />
                                            <SpeedActionTarget>
                                                <AbsoluteTargetSpeed value="5" />
                                            </SpeedActionTarget>
                                        </SpeedAction>
                                    </LongitudinalAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target5lowDownStartTrigger" delay="0" conditionEdge="none">
                                        <ByEntityCondition>
                                            <TriggeringEntities triggeringEntitiesRule="any">
                                                <EntityRef entityRef="Target5" />
                                            </TriggeringEntities>
                                            <EntityCondition>
                                                <DistanceCondition freespace="false" rule="lessOrEqual" value="2">
                                                    <Position>
                                                        <LanePosition laneId="-1" roadId="2" s="5"></LanePosition>
                                                    </Position>
                                                </DistanceCondition>
                                            </EntityCondition>
                                        </ByEntityCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="Target5StopEvent" priority="override">
                            <Action name="Target5StopAction">
                                <PrivateAction>
                                    <LongitudinalAction>
                                        <SpeedAction>
                                            <SpeedActionDynamics dynamicsShape="linear" dynamicsDimension="rate" value="0.5" />
                                            <SpeedActionTarget>
                                                <AbsoluteTargetSpeed value="0" />
                                            </SpeedActionTarget>
                                        </SpeedAction>
                                    </LongitudinalAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target5StopStartTrigger" delay="0" conditionEdge="none">
                                        <ByEntityCondition>
                                            <TriggeringEntities triggeringEntitiesRule="any">
                                                <EntityRef entityRef="Target5" />
                                            </TriggeringEntities>
                                            <EntityCondition>
                                                <DistanceCondition freespace="false" rule="lessOrEqual" value="2">
                                                    <Position>
                                                        <LanePosition laneId="-1" roadId="3" s="7.2"></LanePosition>
                                                    </Position>
                                                </DistanceCondition>
                                            </EntityCondition>
                                        </ByEntityCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="Target5TrajEvent" priority="parallel">
                            <Action name="Target5TrajAction">
                                <PrivateAction>
                                    <RoutingAction>
                                        <FollowTrajectoryAction>
                                            <TimeReference>
                                                <None />
                                            </TimeReference>
                                            <TrajectoryFollowingMode followingMode="position" />
                                            <TrajectoryRef>
                                                <Trajectory name="trajectory_car" closed="false">
                                                    <Shape>
                                                        <ClothoidSpline>
                                                            <ClothoidSplineSegment curvatureStart="0.0" curvatureEnd="0.15" length="15.0"></ClothoidSplineSegment>
                                                            <ClothoidSplineSegment curvatureStart="0.15" curvatureEnd="0.0" length="7.0"></ClothoidSplineSegment>
                                                            <ClothoidSplineSegment curvatureStart="0.0" curvatureEnd="0.0" length="3.0"></ClothoidSplineSegment>
                                                        </ClothoidSpline>
                                                    </Shape>
                                                </Trajectory>
                                            </TrajectoryRef>
                                        </FollowTrajectoryAction>
                                    </RoutingAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target5TrajStartTrigger" delay="0.3" conditionEdge="none">
                                        <ByValueCondition>
                                            <StoryboardElementStateCondition storyboardElementRef="Target5StopEvent" state="startTransition"
                                                storyboardElementType="event" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                    </Maneuver>
                </ManeuverGroup>
                <ManeuverGroup name="Target6ManeuverGroup" maximumExecutionCount="1">
                    <Actors selectTriggeringEntities="false">
                        <EntityRef entityRef="Target6" />
                    </Actors>
                    <CatalogReference catalogName="LightStateManeuvers" entryName="LightsOnWhenDrivingManeuver">
                        <ParameterAssignments>
                            <ParameterAssignment parameterRef="EntityName" value="Target6" />
                        </ParameterAssignments>
                    </CatalogReference>
                    <Maneuver name="Target6Man">
                        <Event name="Target6ManEvent" priority="override">
                            <Action name="Target6TrajAction">
                                <PrivateAction>
                                    <RoutingAction>
                                        <FollowTrajectoryAction>
                                            <TimeReference>
                                                <None />
                                            </TimeReference>
                                            <TrajectoryFollowingMode followingMode="position" />
                                            <TrajectoryRef>
                                                <Trajectory name="trajectory_car" closed="false">
                                                    <Shape>
                                                        <Clothoid curvature="0.0" curvatureDot="-0.0135" length="15.0">
                                                            <Position>
                                                                <RelativeWorldPosition dx="0" dy="0" entityRef="Target6" />
                                                            </Position>
                                                        </Clothoid>
                                                    </Shape>
                                                </Trajectory>
                                            </TrajectoryRef>
                                        </FollowTrajectoryAction>
                                    </RoutingAction>
                                </PrivateAction>
                            </Action>
                            <Action name="Target6SpeedAction">
                                <PrivateAction>
                                    <LongitudinalAction>
                                        <SpeedAction>
                                            <SpeedActionDynamics dynamicsShape="linear" dynamicsDimension="rate" value="3.0" />
                                            <SpeedActionTarget>
                                                <AbsoluteTargetSpeed value="${10 / 3.6}" />
                                            </SpeedActionTarget>
                                        </SpeedAction>
                                    </LongitudinalAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target6ManStopStartTrigger" delay="0" conditionEdge="none">
                                        <ByValueCondition>
                                            <SimulationTimeCondition value="33" rule="greaterOrEqual" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                    </Maneuver>
                </ManeuverGroup>
                <ManeuverGroup name="Target11ManeuverGroup" maximumExecutionCount="1">
                    <Actors selectTriggeringEntities="false">
                        <EntityRef entityRef="Target11" />
                    </Actors>
                    <CatalogReference catalogName="LightStateManeuvers" entryName="LightsOnWhenDrivingManeuver">
                        <ParameterAssignments>
                            <ParameterAssignment parameterRef="EntityName" value="Target11" />
                        </ParameterAssignments>
                    </CatalogReference>
                    <Maneuver name="Target11Man">
                        <Event name="Target11IndicatorEvent" priority="parallel">
                            <Action name="Target11IndicatorAction">
                                <PrivateAction>
                                    <AppearanceAction>
                                        <LightStateAction>
                                            <LightType>
                                                <VehicleLight vehicleLightType="indicatorLeft" />
                                            </LightType>
                                            <LightState mode="flashing" luminousIntensity="600" />
                                        </LightStateAction>
                                    </AppearanceAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target11ManStopStartTrigger" delay="0" conditionEdge="none">
                                        <ByValueCondition>
                                            <SimulationTimeCondition value="23" rule="greaterOrEqual" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="Target11ManEvent" priority="parallel">
                            <Action name="Target11TrajAction">
                                <PrivateAction>
                                    <RoutingAction>
                                        <FollowTrajectoryAction>
                                            <TimeReference>
                                                <None />
                                            </TimeReference>
                                            <TrajectoryFollowingMode followingMode="position" />
                                            <TrajectoryRef>
                                                <Trajectory name="trajectory_target11" closed="false">
                                                    <Shape>
                                                        <ClothoidSpline>
                                                            <ClothoidSplineSegment curvatureStart="0.1" curvatureEnd="0.0" length="8"></ClothoidSplineSegment>
                                                            <ClothoidSplineSegment curvatureStart="0.0" curvatureEnd="-0.02" length="8.0"></ClothoidSplineSegment>
                                                        </ClothoidSpline>
                                                    </Shape>
                                                </Trajectory>
                                            </TrajectoryRef>
                                        </FollowTrajectoryAction>
                                    </RoutingAction>
                                </PrivateAction>
                            </Action>
                            <Action name="Target6SpeedAction">
                                <PrivateAction>
                                    <LongitudinalAction>
                                        <SpeedAction>
                                            <SpeedActionDynamics dynamicsShape="linear" dynamicsDimension="rate" value="3.0" />
                                            <SpeedActionTarget>
                                                <AbsoluteTargetSpeed value="${$Speed / 3.6}" />
                                            </SpeedActionTarget>
                                        </SpeedAction>
                                    </LongitudinalAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="Target6ManStopStartTrigger" delay="0" conditionEdge="none">
                                        <ByValueCondition>
                                            <SimulationTimeCondition value="27" rule="greaterOrEqual" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                    </Maneuver>
                </ManeuverGroup>
                <ManeuverGroup name="ManManeuverGroup" maximumExecutionCount="1">
                    <Actors selectTriggeringEntities="false">
                        <EntityRef entityRef="Man1" />
                    </Actors>
                    <Maneuver name="ManMoveManeuver">
                        <Event name="ManMoveEvent" priority="overwrite">
                            <Action name="ManMovementAction">
                                <PrivateAction>
                                    <RoutingAction>
                                        <FollowTrajectoryAction>
                                            <TimeReference>
                                                <None />
                                            </TimeReference>
                                            <TrajectoryFollowingMode followingMode="position" />
                                            <TrajectoryRef>
                                                <Trajectory name="trajectory_man" closed="false">
                                                    <Shape>
                                                        <Polyline>
                                                            <Vertex>
                                                                <Position>
                                                                    <RoadPosition roadId="1" s="20.0" t="-7">
                                                                    </RoadPosition>
                                                                </Position>
                                                            </Vertex>
                                                            <Vertex>
                                                                <Position>
                                                                    <RoadPosition roadId="1" s="10.0" t="-7">
                                                                    </RoadPosition>
                                                                </Position>
                                                            </Vertex>
                                                            <Vertex>
                                                                <Position>
                                                                    <RoadPosition roadId="1" s="9.5" t="-6.5">
                                                                    </RoadPosition>
                                                                </Position>
                                                            </Vertex>
                                                            <Vertex>
                                                                <Position>
                                                                    <RoadPosition roadId="1" s="9.5" t="5.5">
                                                                    </RoadPosition>
                                                                </Position>
                                                            </Vertex>
                                                            <Vertex>
                                                                <Position>
                                                                    <RoadPosition roadId="1" s="10.0" t="6.0">
                                                                    </RoadPosition>
                                                                </Position>
                                                            </Vertex>
                                                            <Vertex>
                                                                <Position>
                                                                    <RoadPosition roadId="1" s="16.0" t="6.0">
                                                                    </RoadPosition>
                                                                </Position>
                                                            </Vertex>
                                                        </Polyline>
                                                    </Shape>
                                                </Trajectory>
                                            </TrajectoryRef>
                                        </FollowTrajectoryAction>
                                    </RoutingAction>
                                </PrivateAction>
                            </Action>
                        </Event>
                        <Event name="ManStopEvent" priority="override">
                            <Action name="ManStopAction">
                                <PrivateAction>
                                    <LongitudinalAction>
                                        <SpeedAction>
                                            <SpeedActionDynamics dynamicsShape="linear" dynamicsDimension="rate" value="5.0" />
                                            <SpeedActionTarget>
                                                <AbsoluteTargetSpeed value="0" />
                                            </SpeedActionTarget>
                                        </SpeedAction>
                                    </LongitudinalAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="ManStopStartTrigger" delay="0" conditionEdge="none">
                                        <ByValueCondition>
                                            <StoryboardElementStateCondition storyboardElementRef="ManMovementAction" state="endTransition"
                                                storyboardElementType="action" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                    </Maneuver>
                </ManeuverGroup>
                <ManeuverGroup name="CameraManeuverGroup" maximumExecutionCount="1">
                    <Actors selectTriggeringEntities="false">
                        <EntityRef entityRef="Camera" />
                    </Actors>
                    <Maneuver name="cameraMotion">
                        <Event name="cameraMotionEvent" priority="override">
                            <Action name="cameraMotionAction">
                                <PrivateAction>
                                    <RoutingAction>
                                        <FollowTrajectoryAction>
                                            <TrajectoryRef>
                                                <Trajectory closed="true" name="TrajectoryPLine">
                                                    <ParameterDeclarations />
                                                    <Shape>
                                                        <Nurbs order="3">
                                                            <ControlPoint time="0" weight="1">
                                                                <Position>
                                                                    <WorldPosition x="-10.0" y="-13.0" z="10.0" h="0.4" p="0.33" />
                                                                </Position>
                                                            </ControlPoint>
                                                            <ControlPoint time="20" weight="1">
                                                                <Position>
                                                                    <WorldPosition x="150.0" y="40.0" z="15.0" h="0.3" p="0.5" />
                                                                </Position>
                                                            </ControlPoint>
                                                            <ControlPoint time="35" weight="1">
                                                                <Position>
                                                                    <WorldPosition x="140.0" y="-80.0" z="11" h="-2.65" p="0.4" />
                                                                </Position>
                                                            </ControlPoint>
                                                            <Knot value="0.0" />
                                                            <Knot value="0.0" />
                                                            <Knot value="0.0" />
                                                            <Knot value="1.0" />
                                                            <Knot value="1.0" />
                                                            <Knot value="1.0" />
                                                        </Nurbs>
                                                    </Shape>
                                                </Trajectory>
                                            </TrajectoryRef>
                                            <TimeReference>
                                                <Timing domainAbsoluteRelative="relative" offset="0" scale="1" />
                                            </TimeReference>
                                            <TrajectoryFollowingMode followingMode="position" />
                                        </FollowTrajectoryAction>
                                    </RoutingAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition conditionEdge="none" delay="0" name="StartCamera">
                                        <ByValueCondition>
                                            <SimulationTimeCondition rule="greaterOrEqual" value="$CameraStartTime" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                        <Event name="cameraStopEvent" priority="override">
                            <Action name="cameraStopAction">
                                <PrivateAction>
                                    <LongitudinalAction>
                                        <SpeedAction>
                                            <SpeedActionDynamics dynamicsDimension="time" dynamicsShape="step" value="0" />
                                            <SpeedActionTarget>
                                                <AbsoluteTargetSpeed value="0" />
                                            </SpeedActionTarget>
                                        </SpeedAction>
                                    </LongitudinalAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition conditionEdge="none" delay="0" name="StartCamera">
                                        <ByValueCondition>
                                            <StoryboardElementStateCondition storyboardElementRef="cameraMotionAction" state="endTransition"
                                                storyboardElementType="action" />
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                    </Maneuver>
                </ManeuverGroup>
            </Act>
        </Story>
        <StopTrigger>
            <ConditionGroup>
                <Condition name="ScenarioStopTrigger" delay="0" conditionEdge="none">
                    <ByValueCondition>
                        <SimulationTimeCondition value="50" rule="greaterOrEqual" />
                    </ByValueCondition>
                </Condition>
            </ConditionGroup>
        </StopTrigger>
    </Storyboard>
</OpenSCENARIO>