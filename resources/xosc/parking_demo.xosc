        </ScenarioObject>
        <ScenarioObject name="Camera">
            <MiscObject name="camera_object" miscObjectCategory="none" mass="200.0">
                <ParameterDeclarations />
                <BoundingBox>
                    <Center x="0.0" y="0.0" z="0.25" />
                    <Dimensions width="0.5" length="0.5" height="0.5" />
                </BoundingBox>
            </MiscObject>
        </ScenarioObject>
    </Entities>
    <Storyboard>
        <Init>
