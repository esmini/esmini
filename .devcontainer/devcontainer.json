{
  "name": "esmini",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerEnv": {
    "HTTP_PROXY": "${localEnv:HTTP_PROXY}",
    "HTTPS_PROXY": "${localEnv:HTTPS_PROXY}",
    "NO_PROXY": "${localEnv:NO_PROXY}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cmake-tools",
        "cheshirekow.cmake-format"
      ]
    }
  },
  "remoteUser": "ubuntu"
}
